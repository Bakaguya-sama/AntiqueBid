generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["driverAdapters"] 
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  user
}

enum AntiqueStatus {
  available
  sold
  unavailable
}

enum AuctionStatus {
  not_started
  active
  finished
  cancelled
}

enum NotificationType {
  outbid
  win
  lose
  auction_update
  system_announcement
}

enum NotificationScope {
  personal
  system
}

model User {
  id String @id @default(uuid()) @db.Uuid
  fullName String
  userName String @unique 
  email String @unique
  password String?
  role UserRole @default(user)
  isActive Boolean @default(true)    
  lastLoginAt DateTime?  @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  antique_creator Antique[] @relation("AntiqueCreator")
  otp_use OTPUser[] @relation("OtpUse")
  identity UserIdentity[] @relation("Identity")
  auction_seller Auction[] @relation("AuctionSeller")
  auction_winner Auction[] @relation("AuctionWinner")
  auction_bidder Bid[] @relation("AuctionBidder")
  notification_recipient NotificationReadReceipt[] @relation("NotificationReadReceipts")
  notification_recipient2 Notification[] @relation("NotificationRecipient")
}

model UserIdentity {
  id String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  provider String
  providerId String
  accessToken String?
  refreshToken String?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  user User @relation("Identity", fields: [userId], references: [id])

  @@unique([provider, providerId])
  @@unique([userId, provider])
}

model OTPUser {
  id String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  otpCode String 
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  isUsed Boolean @default(false)

  user User @relation("OtpUse", fields: [userId], references: [id])
}

model Antique {
  id String @id @default(uuid()) @db.Uuid
  name String
  description String
  status AntiqueStatus @default(available)
  createdBy String @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  auctionAntiques  AuctionAntique[]  @relation("AntiqueToAuctionAntique")
  
  antiqueCreator User @relation("AntiqueCreator", fields: [createdBy], references: [id])
}

model AuctionAntique {
  auctionId  String @db.Uuid
  antiqueId  String @db.Uuid

  auction  Auction @relation("AuctionToAuctionAntique", fields: [auctionId], references: [id])
  antique  Antique @relation("AntiqueToAuctionAntique", fields: [antiqueId], references: [id])

  @@id([auctionId, antiqueId])  
}

model Auction {
  id String @id @default(uuid()) @db.Uuid
  sellerId String @db.Uuid
  startingPrice Decimal @db.Decimal(15, 2) @default(0)
  stepPrice Decimal @db.Decimal(15, 2) @default(0)
  currentPrice Decimal @db.Decimal(15, 2) @default(0)
  startsAt DateTime
  endsAt DateTime
  status AuctionStatus @default(not_started)
  winnerId String? @db.Uuid 
  createdAt         DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime    @updatedAt @db.Timestamptz(3)
  lastBidAt DateTime? @db.Timestamptz(3)
  extendCount       Int @default(0)   // Bắt đầu với 0 lần gia hạn
  maxExtendCount    Int @default(10)  // Tối đa gia hạn 10 lần
  extendWindowSec   Int @default(300) // Khung giờ phút chót là 5 phút
  extendDurationSec Int @default(300) // Mỗi lần gia hạn cộng thêm 5 phút
  deletedAt DateTime? @db.Timestamptz(3)
    

  auction_bid Bid[] @relation("AuctionBid")

  auctionSeller User @relation("AuctionSeller", fields: [sellerId], references: [id])
  auctionAntiques AuctionAntique[] @relation("AuctionToAuctionAntique")
  auctionWinner User? @relation("AuctionWinner", fields: [winnerId], references: [id])

  @@index([status], name: "idx_auction_status")
  @@index([status, endsAt], name: "idx_auction_status_endsAt")
}

model Bid {
  id String @id @default(uuid()) @db.Uuid
  auctionId String @db.Uuid
  userId String @db.Uuid
  price Decimal @db.Decimal(15, 2) @default(0) 
  isValid Boolean @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)


  auctionBid Auction @relation("AuctionBid", fields: [auctionId], references: [id])
  auctionBidder User @relation("AuctionBidder", fields: [userId], references: [id])

  @@index([auctionId], name: "idx_bids_auction")
  @@index([price(sort: Desc)], name: "idx_bids_price")
}

model Notification {
  id String @id @default(uuid()) @db.Uuid
  userId    String?          @db.Uuid  
  type NotificationType   @default(system_announcement)  
  scope NotificationScope @default(system)   
  message String
  metadata  Json?
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)

  readReceipts NotificationReadReceipt[] @relation("NotificationReadReceipts")

  notficationRecipient User? @relation("NotificationRecipient", fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)], name: "idx_noti_userId_createdAt")
  @@index([createdAt(sort: Desc)],         name: "idx_noti_system_createdAt")
}


model NotificationReadReceipt {
  notificationId String @db.Uuid
  userId String @db.Uuid
  readAt DateTime @default(now()) @db.Timestamptz(3)

  notification Notification @relation("NotificationReadReceipts", fields: [notificationId], references: [id])
  user User @relation("NotificationReadReceipts", fields: [userId], references: [id])


  @@id([notificationId, userId])
  @@index([userId], name: "idx_receipt_userId") 
}